{
  "name": "EFTMRA-India-CMS",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "predev": "npm run generate:types && npm run generate:importmap",
    "dev": "next dev -p 3001",
    "prebuild": "npm run generate:types && npm run generate:importmap",
    "build": "next build",
    "prestart": "npm run generate:types && npm run generate:importmap",
    "start": "next start -p ${PORT:-3001}",
    "deploy": "npm run migrate && npm run build",
    "payload": "payload",
    "migrate": "payload migrate && tsx scripts/sync-seeds-if-changed.ts",
    "migrate:schema": "payload migrate",
    "sync:seeds": "tsx scripts/sync-seeds-if-changed.ts",
    "seed:trainers": "tsx scripts/seed-trainers.ts",
    "export:allseeds": "tsx scripts/export-all.ts",
    "migrate:status": "payload migrate:status",
    "migrate:down": "payload migrate:down",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:types": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@payloadcms/db-postgres": "3.81.0",
    "@payloadcms/db-sqlite": "3.81.0",
    "@payloadcms/next": "3.81.0",
    "@payloadcms/plugin-seo": "3.81.0",
    "@payloadcms/richtext-lexical": "3.81.0",
    "@payloadcms/ui": "3.81.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@types/nodemailer": "^8.0.0",
    "cli-color": "^2.0.4",
    "dotenv": "^17.4.2",
    "graphql": "^16.13.2",
    "lucide-react": "^1.14.0",
    "next": "15.4.11",
    "nodemailer": "^8.0.8",
    "payload": "3.81.0",
    "pg": "^8.20.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "22.7.4",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "postcss": "8.4.47",
    "tailwindcss": "4.2.0",
    "typescript": "5.6.2"
  }
}
