  {
    "id": 1,
    "name": "Mridula Nair",
    "tagline": "Transforming lives through EFT. Leading India's internationally accredited academy with passion, expertise, and compassion.",
    "image": {
      "id": 1004,
      "alt": null,
      "updatedAt": "2026-05-18T12:35:06.174Z",
      "createdAt": "2026-05-18T12:35:06.174Z",
      "url": "http://localhost:3001/api/media/file/Mridula-Nair.jpeg",
      "thumbnailURL": null,
      "filename": "Mridula-Nair.jpeg",
      "mimeType": "image/jpeg",
      "filesize": 103017,
      "width": 690,
      "height": 690,
      "focalX": 50,
      "focalY": 50
    },
    "imageAlt": "Mridula Nair",
    "aboutLabel": "About Mridula",
    "aboutTitle": "A Pioneer in Emotional Healing",
    "philosophy": "Effective EFT training is not just about techniques. It is about creating a safe, judgment-free space where practitioners can heal themselves while learning to support others with competence and compassion.",
    "aboutParagraphs": [
      {
        "id": "6a16da40384211b38f54ed28",
        "content": "Mridula Nair is the founder and Head Master Trainer of EFTMRA India, the academy in India authorised by EFTMRA U.K. to certify practitioners to global standards."
      },
      {
        "id": "6a16da40384211b38f54ed29",
        "content": "Her journey into EFT began as a personal healing practice and evolved into a mission to build skilled, ethical, and compassionate EFT practitioners across India."
      },
      {
        "id": "6a16da40384211b38f54ed2a",
        "content": "As a Master Trainer and practitioner, Mridula brings technical expertise, lived wisdom, and years of experience working with emotional healing and transformation."
      }
    ],
    "credentials": [
      {
        "id": "6a16da40384211b38f54ed2b",
        "label": "EFTMRA Master Trainer of Trainers"
      },
